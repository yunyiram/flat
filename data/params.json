  "slider_semantics": {
    "description": "Human-readable labels for slider value ranges. Maps numeric ranges to garment terminology.",
    "neckDepth": { "0-29": "shallow", "30-64": "normal", "65-100": "deep" },
    "neckCurve": { "0-5": "square", "6-14": "v", "15-49": "angular", "50-79": "round", "80-100": "u-shape" },
    "neckWidth": { "0-24": "narrow", "25-54": "normal", "55-79": "wide", "80-100": "boat" },
    "shoulderSlope": { "0-29": "gentle", "30-64": "normal", "65-100": "steep" },
    "shoulderExtra": { "<-3": "narrow", "-3 to 4": "natural", "5-12": "extended", "13+": "drop" },
    "sleeveLength": { "0-2": "sleeveless", "3-18": "cap", "19-41": "short", "42-61": "elbow", "62-81": "three-quarter", "82+": "long" },
    "sleeveWidth": { "0-29": "tight", "30-64": "normal", "65+": "wide" },
    "hipFlare": { "<-3": "taper", "-3 to 1": "straight", "2-6": "slight A", "7-10": "A/cocoon", "11+": "A-line" },
    "fitW": { "0-15": "skin", "16-37": "slim", "38-57": "regular", "58-75": "relaxed", "76-89": "oversized", "90+": "boxy" },
    "bodyLen": { "0-19": "crop", "20-54": "standard", "55-79": "hip", "80+": "long" },
    "skirtLen": { "0-29": "mini", "30-44": "above knee", "45-59": "knee", "60-79": "midi", "80+": "maxi" },
    "pantsLen": { "0-19": "hot pants", "20-34": "shorts", "35-49": "bermuda", "50-69": "cropped", "70+": "full length" },
    "pantsFit": { "0-19": "skinny", "20-39": "slim", "40-59": "regular", "60-79": "relaxed", "80+": "wide" }
  },

  "body_size_mapping": {
    "description": "Body measurement (bust/waist/hip in cm) to slider value conversion. Uses Donnanno ease + inverse CM_MAP.",
    "bust_to_chest_slider": {
      "formula": "clamp(0, 100, round((bust + ease - 78) / 0.42))",
      "ease_source": "ease_by_garment.code_ease_map"
    },
    "hip_to_flare_slider": {
      "formula": "clamp(-10, 16, round((hip - bust) * 0.4))",
      "note": "Hip flare derived from hip-bust difference."
    }
