    "sleeveLength": { "normal": 100, "extended": 160, "note": "Theatrical gathered sleeves" },
    "bodyLen":      { "normal": 100, "extended": 150, "note": "Extreme length" },
    "sleeveWidth":  { "normal": 100, "extended": 160, "note": "Extreme balloon" },
    "fitW":         { "normal": 100, "extended": 140, "note": "Extreme oversize" },
    "neckDepth":    { "normal": 100, "extended": 130, "note": "Extreme plunge" },
