  "garment_defaults": {
    "description": "Default overrides applied when switching garment type. Resets key params to category-appropriate values. Source: Donnanno Vol.3 p.15 ease-by-garment mapping.",
    "top": {
      "bodyLen": 45,
      "fitW": 50,
      "closure": "none",
      "closureStyle": "single",
      "neckShape": "round",
      "shoulderType": "standard",
      "neckDetail": "none"
    },
    "dress": {
      "bodyLen": 80,
      "fitW": 46,
      "silhouette": "a_line",
      "hipFlare": 8,
      "dart": "bust",
      "closure": "none",
      "closureStyle": "single",
      "neckShape": "round",
      "shoulderType": "standard",
      "neckDetail": "none"
    },
    "outerwear": {
      "bodyLen": 60,
      "fitW": 70,
      "closure": "button",
