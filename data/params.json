    "shoulderExtra":{ "normal": 20,  "extended": 40,  "note": "Extreme drop" },
    "skirtFlare":   { "normal": 40,  "extended": 70,  "note": "Extreme skirt flare" },
    "pantsFlare":   { "normal": 30,  "extended": 55,  "note": "Extreme pants flare" }
  },

  "style_overlays": {
    "description": "Style overlay delta vectors. Applied on top of current state. Deltas are additive (clamped to min 0); overrides replace the value. Removable -- base values are snapshotted before apply.",
    "casual": {
      "deltas": { "fitW": 8, "shoulderSlope": -5 },
      "overrides": { "dart": "none", "stitchType": "single" }
    },
    "formal": {
      "deltas": { "fitW": -5, "shoulderSlope": 5, "shoulderExtra": -2 },
      "overrides": { "dart": "bust", "stitchType": "double", "sideSeam": "yes" }
    },
    "military": {
      "deltas": { "shoulderExtra": 5, "fitW": 5 },
      "overrides": { "pocket": "cargo", "pocketY": 32, "stitchType": "double", "hemFinish": "folded", "shoulderLine": "extended" }
    },
    "workwear": {
      "deltas": { "fitW": 10, "chest": 8 },
      "overrides": { "pocket": "chest_two", "stitchType": "double", "hemFinish": "folded" }
    },
    "sport": {
      "deltas": { "fitW": 12, "sleeveWidth": 10 },
      "overrides": { "sleeveType": "raglan", "hemFinish": "rib", "sleeveCuff": "rib", "dart": "none" }
    },
    "minimal": {
      "deltas": {},
      "overrides": { "pocket": "none", "trimming": "none", "dart": "none", "closure": "none", "neckDetail": "none" }
    },
    "romantic": {
      "deltas": { "neckDepth": 10, "sleeveWidth": 15 },
      "overrides": { "sleeveShape": "puff", "hemShape": "curved" }
    }
  },

